{
  "description": "Model-loop batch using repaired history logging. This config reruns the v5 S3-tail champion as a clean logging reference, then tests two mild S3 magnitude-loss candidates on the same cached v5 dataset and writes compact comparison diagnostics.",
  "config_id": "v5-logging-s3magloss-batch",
  "cycles": 8,
  "sleep_seconds": 30,
  "branch": "main",
  "reload_config_each_cycle": true,
  "configure_token_remote": true,
  "repo_slug": "DrYGuo/Aberration-Simulation",
  "git_pull_before_cycle": true,
  "git_push_after_cycle": true,
  "commit_message_prefix": "Add Colab model-loop artifacts",
  "command": [
    "bash",
    "scripts/run_colab_v5_logging_s3magloss_workflow.sh"
  ],
  "result_globs": [
    "colab_worker_logs/*.json",
    "colab_worker_logs/*.log",
    "training_results/feature_regression_enhanced/**/dataset_manifest.json",
    "training_results/feature_regression_enhanced/**/targeted25k_audit.json",
    "training_results/feature_regression_enhanced/**/*summary.csv",
    "training_results/feature_regression_enhanced/**/feature_columns_enhanced.json",
    "training_results/feature_regression_enhanced/**/hard_target_histograms/*.png",
    "training_results/model_selection_reports/s3_feature_saturation_audit_*.md",
    "training_results/model_selection_reports/s3_feature_saturation_audit_*.json",
    "training_results/model_selection_reports/s3_magnitude_metric_audit_*.md",
    "training_results/model_selection_reports/s3_magnitude_metric_audit_*/*.json",
    "training_results/model_selection_reports/s3_magnitude_metric_audit_*/plots/*.png",
    "training_results/model_selection_reports/training_validation_loss_gap_audit_*.md",
    "training_results/model_selection_reports/training_validation_loss_gap_audit_*/*.json",
    "training_results/model_selection_reports/training_validation_loss_gap_audit_*/plots/*.png",
    "training_results/model_selection_loop/**/run_manifest*.json",
    "training_results/model_selection_loop/**/metrics*.json",
    "training_results/model_selection_loop/**/orthogonal_benchmark_metrics.json",
    "training_results/model_selection_loop/**/per_target_diagnostics.json",
    "training_results/model_selection_loop/**/vector_diagnostics.json",
    "training_results/model_selection_loop/**/*failure*.json",
    "training_results/model_selection_loop/**/selection*.json",
    "training_results/model_selection_loop/**/s3_magnitude_metric_audit_validation.csv",
    "training_results/model_selection_loop/**/model_registry*.csv",
    "training_results/model_selection_loop/**/*summary.csv",
    "training_results/model_selection_loop/**/*.png",
    "training_results/model_selection_batches/**/batch_manifest.json",
    "training_results/model_selection_batches/**/batch_summary.csv",
    "training_results/orthogonal_benchmarks/**/orthogonal_design_manifest.json",
    "training_results/orthogonal_benchmarks/**/factor_balance_summary.json",
    "training_results/orthogonal_benchmarks/**/factor_correlation_matrix.csv",
    "training_results/orthogonal_benchmarks/**/orthogonal_design_table.csv",
    "training_results/orthogonal_benchmarks/**/*.png"
  ],
  "artifact_manifest_dir": "colab_worker_logs",
  "stop_on_command_failure": true,
  "command_timeout_seconds": 10800,
  "artifact_max_bytes": 1500000,
  "artifact_blocked_suffixes": [
    ".pt",
    ".pth",
    ".ckpt",
    ".zip",
    ".npy",
    ".npz",
    ".h5"
  ],
  "artifact_blocked_patterns": [
    "training_features",
    "predictions",
    "checkpoint"
  ],
  "push_every_n_cycles": 1,
  "push_on_final_cycle": true,
  "require_new_config_each_cycle": false,
  "wait_for_new_config_poll_seconds": 30,
  "wait_for_new_config_timeout_seconds": 7200
}

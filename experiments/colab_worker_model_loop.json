{
  "description": "Real model-selection loop. Bootstraps the enhanced feature CSV once if missing, then reuses cached feature CSVs for model candidates and waits for Codex to push changed configs between cycles.",
  "config_id": "model-loop-d66-width128-lr4e-4-dropout0.05",
  "cycles": 8,
  "sleep_seconds": 30,
  "branch": "main",
  "reload_config_each_cycle": true,
  "configure_token_remote": true,
  "repo_slug": "DrYGuo/Aberration-Simulation",
  "git_pull_before_cycle": true,
  "git_push_after_cycle": true,
  "commit_message_prefix": "Add Colab model-loop artifacts",
  "command": [
    "python3",
    "scripts/run_model_selection_candidate.py",
    "--family",
    "enhanced",
    "--candidate-id",
    "D66_width128_lr4e-4_dropout0.05",
    "--search-root",
    "training_results",
    "--output-root",
    "training_results/model_selection_loop",
    "--hidden-dim",
    "128",
    "--dropout",
    "0.05",
    "--learning-rate",
    "4e-4",
    "--weight-decay",
    "1e-4",
    "--residual-penalty",
    "3e-3",
    "--max-epochs",
    "6000",
    "--eval-every",
    "25",
    "--patience-epochs",
    "1000",
    "--easy-regression-limit",
    "0.10",
    "--bootstrap-if-missing",
    "--bootstrap-notebook",
    "notebooks/uno_feature_regression_enhanced_dataset_bootstrap.ipynb",
    "--bootstrap-timeout",
    "3600"
  ],
  "result_globs": [
    "colab_worker_logs/*.json",
    "colab_worker_logs/*.log",
    "training_results/model_selection_loop/**/run_manifest*.json",
    "training_results/model_selection_loop/**/metrics*.json",
    "training_results/model_selection_loop/**/*failure*.json",
    "training_results/model_selection_loop/**/selection*.json",
    "training_results/model_selection_loop/**/model_registry*.csv",
    "training_results/model_selection_loop/**/*summary*.csv",
    "training_results/model_selection_loop/**/amplitude_bin_metrics*.csv",
    "training_results/model_selection_loop/**/feature_scale_summary*.csv",
    "training_results/model_selection_loop/**/target_scale_summary*.csv",
    "training_results/model_selection_loop/**/*.png"
  ],
  "artifact_manifest_dir": "colab_worker_logs",
  "stop_on_command_failure": true,
  "command_timeout_seconds": 3600,
  "artifact_max_bytes": 1500000,
  "artifact_blocked_suffixes": [
    ".pt",
    ".pth",
    ".ckpt",
    ".zip",
    ".npy",
    ".npz",
    ".h5"
  ],
  "artifact_blocked_patterns": [
    "training_features",
    "predictions",
    "checkpoint"
  ],
  "push_every_n_cycles": 1,
  "push_on_final_cycle": true,
  "require_new_config_each_cycle": true,
  "wait_for_new_config_poll_seconds": 30,
  "wait_for_new_config_timeout_seconds": 7200
}

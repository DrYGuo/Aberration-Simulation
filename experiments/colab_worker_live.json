{
  "description": "Live steering test with per-cycle artifact push and stale-config protection. Codex set step 17 while monitoring GitHub.",
  "config_id": "live-steering-step-17",
  "cycles": 12,
  "sleep_seconds": 45,
  "branch": "main",
  "reload_config_each_cycle": true,
  "configure_token_remote": true,
  "repo_slug": "DrYGuo/Aberration-Simulation",
  "git_pull_before_cycle": true,
  "git_push_after_cycle": true,
  "commit_message_prefix": "Add Colab final live steering artifacts",
  "command": [
    "python3",
    "-c",
    "from datetime import datetime, timezone; print('LIVE_STEERING_STEP=17'); print('message=Codex advanced guarded live loop to step 17 after evaluating cycle 11'); print('utc', datetime.now(timezone.utc).isoformat())"
  ],
  "result_globs": [
    "colab_worker_logs/*.json",
    "training_results/**/run_manifest*.json",
    "training_results/**/metrics*.json",
    "training_results/**/model_registry*.csv",
    "training_results/**/*summary*.csv",
    "training_results/**/amplitude_bin_metrics*.csv",
    "training_results/**/feature_scale_summary*.csv",
    "training_results/**/target_scale_summary*.csv",
    "training_results/**/*.png"
  ],
  "artifact_manifest_dir": "colab_worker_logs",
  "stop_on_command_failure": true,
  "command_timeout_seconds": 3600,
  "artifact_max_bytes": 1500000,
  "artifact_blocked_suffixes": [
    ".pt",
    ".pth",
    ".ckpt",
    ".zip",
    ".npy",
    ".npz",
    ".h5"
  ],
  "artifact_blocked_patterns": [
    "training_features",
    "predictions",
    "checkpoint"
  ],
  "push_every_n_cycles": 1,
  "push_on_final_cycle": true,
  "require_new_config_each_cycle": true,
  "wait_for_new_config_poll_seconds": 30,
  "wait_for_new_config_timeout_seconds": 7200
}

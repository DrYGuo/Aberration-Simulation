    "C3": 2.0,
    "A1_x": 60.0,
    "A1_y": 60.0,
    "B2_x": 3.0,
    "B2_y": 3.0,
    "A2_x": 16.0,
    "A2_y": 16.0,
    "S3_x": 100.0,
    "S3_y": 100.0,
    "A3_x": 100.0,
    "A3_y": 100.0
  },
  "proposal": {
    "seed": 1507,
    "selected_probe_count": 3000,
    "candidate_pool_size": 45000,
    "reference_sample_size": 300000,
    "nearest_neighbor_chunk_size": 25000,
    "top_residual_seed_count": 1200,
    "mode_counts": {
      "far_nn": 900,
      "sobol_lhs": 650,
      "genetic_algorithm": 800,
      "residual_jitter": 350,
      "bridge_anchor": 300
    },
    "regime_weights": {
      "coupled_full_random": 0.30,
      "coupled_sparse_random": 0.18,
      "coupled_A3_S3_random": 0.12,
      "coupled_B2_S3_random": 0.10,
      "coupled_A1_B2_S3_random": 0.10,
      "coupled_A1_S3_random": 0.08,
      "coupled_C3_A3_S3_random": 0.08,
      "S3_high_random": 0.04
    },
    "genetic_algorithm": {
      "population_size": 768,
      "generations": 24,
      "elite_fraction": 0.16,
      "mutation_probability": 0.18,
      "mutation_scale": 0.10,
      "immigrant_fraction": 0.08,
      "fitness_weights": {
        "nearest_neighbor_distance": 0.50,
        "known_residual_similarity": 0.22,
        "physical_relevance": 0.14,
        "diversity_proxy": 0.08,
        "boundary_penalty": 0.06

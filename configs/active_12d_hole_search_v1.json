  "recommended_plan": {
    "future_dataset_name": "v15_active_hole_targeted",
    "do_not_train_in_this_workflow": true,
    "starting_policy": "Use the resulting failure clusters to allocate a future diagnostic-to-training expansion. Do not promote a data-expansion plan until this active search finishes."
  },
  "artifact_policy": {
    "github_lightweight_only": true,
    "drive_backup_large_artifacts": true,
    "do_not_push": [
